# =========================================
# PandaHub Environment Configuration
# Copy this file to `.env` and fill in real values before running `make up`
# =========================================

# ---------- General ----------
ENVIRONMENT=development           # development | staging | production
DEBUG=true
PROJECT_NAME=PandaHub
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ---------- PostgreSQL ----------
POSTGRES_USER=pandahub
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=pandahub
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://pandahub:change_me_in_production@postgres:5432/pandahub

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ---------- JWT / Auth ----------
JWT_SECRET_KEY=change_me_super_secret_key_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------- OAuth (optional providers) ----------
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---------- Email (verification / notifications) ----------
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@pandahub.dev
SMTP_TLS=true

# ---------- MinIO / Object Storage ----------
MINIO_ROOT_USER=pandahub_admin
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_AVATARS=pandahub-avatars
MINIO_BUCKET_LFS=pandahub-lfs
MINIO_BUCKET_ARTIFACTS=pandahub-artifacts
MINIO_USE_SSL=false

# ---------- Git Storage ----------
GIT_REPOS_ROOT=/data/repositories
GIT_HTTP_ROUTE_PREFIX=/git

# ---------- AI Service ----------
AI_PROVIDER=anthropic              # anthropic | openai | local
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# ---------- Celery ----------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------- Rate Limiting ----------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_GIT_OPS_PER_MINUTE=30

# ---------- CORS ----------
CORS_ALLOWED_ORIGINS=http://localhost:3000
